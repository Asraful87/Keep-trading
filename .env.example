# Discord bot token (required)
DISCORD_TOKEN=your-bot-token-here

# Application / client ID (required for slash command registration)
CLIENT_ID=your-application-id-here

# Guild where the bot is active. Commands are registered per-guild for instant updates.
# Leave empty to register globally (can take up to 1 hour to propagate).
GUILD_ID=

# Channel where join events and anti-raid alerts are logged.
LOGS_CHANNEL_ID=

# Channel where the welcome message is posted. If empty, the welcome is DMed to the new member.
WELCOME_CHANNEL_ID=

# --- Anti-raid settings ---
# Number of joins within TIME_WINDOW_MS that triggers a raid alert.
ANTI_RAID_JOIN_THRESHOLD=5
# Time window in milliseconds used to detect a join storm.
ANTI_RAID_TIME_WINDOW_MS=10000

# --- Embed Builder Web Dashboard ---
# Set to "false" to disable the local web dashboard entirely.
DASHBOARD_ENABLED=true
# Port the dashboard HTTP server listens on.
DASHBOARD_PORT=3000
# Shared access token for the dashboard (interim auth). Send as
# "Authorization: Bearer <token>" from the dashboard UI. REQUIRED.
EMBED_DASHBOARD_TOKEN=
# Channel where uploaded images are parked to obtain a Discord CDN URL.
# The bot must have Send Messages + Attach Files there.
EMBED_MEDIA_CHANNEL_ID=
